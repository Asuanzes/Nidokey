DATABASE_URL="postgresql://nidokey:nidokey@localhost:5432/nidokey?schema=public"

# ─── LLM que estructura los menús (Crawl4AI da markdown → LLM lo pasa a carta JSON) ───
# Se elige por env, priorizando el GRATIS: Gemini → Claude. SOLO servidor.
# Sin ninguno, el scraping gratis (Crawl4AI) se apaga y se cae al respaldo de Firecrawl.
#
# Google Gemini (gratis, pero su free tier depende de cuenta/región/billing):
# clave en https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Opcional: modelo (default gemini-2.0-flash).
GEMINI_MODEL=""
# Groq (RECOMENDADO si Gemini da problemas de billing): gratis, SIN tarjeta ni
# proyectos. Clave en https://console.groq.com/keys (empieza por gsk_).
GROQ_API_KEY=""
# Opcional: modelo (default llama-3.3-70b-versatile).
GROQ_MODEL=""
# Anthropic (Claude) — alternativa de pago. Clave en console.anthropic.com.
ANTHROPIC_API_KEY=""
# Opcional: modelo (default claude-haiku-4-5-20251001).
ANTHROPIC_MODEL=""

# Catastro: la API es pública y sin clave, pero por si añadimos cache/proxy
CATASTRO_BASE_URL="https://ovc.catastro.meh.es/ovcservweb/OVCSWLocalizacionRC"

# ─── Auth (NextAuth + Resend) ───
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:4200"
# Resend API key (https://resend.com/api-keys). Si vacío, los magic-links se imprimen en consola del dev server.
RESEND_API_KEY=""
# Remitente. Para empezar usa "Nidokey <onboarding@resend.dev>" (Resend lo permite sin verificar dominio para enviarte solo a ti).
# Una vez verifiques un dominio, usa "Nidokey <noreply@nidokey.es>".
RESEND_FROM="Nidokey <onboarding@resend.dev>"

# ─── Cron / refresh programado ───
# Secreto compartido para los endpoints /api/cron/*. Lo envían cron-job.org y
# GitHub Actions como "Authorization: Bearer $CRON_SECRET". Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# ─── Fuentes externas (datos de registros) ───
# Twelve Data (mercados/bolsa): https://twelvedata.com — clave del lado servidor,
# NUNCA en el cliente. Valor real en .env.local (gitignored) y en Vercel env.
TWELVEDATA_API_KEY=""

# ─── Apify (ingesta de ofertas de empleo — POC) ───
# Token SOLO en el servidor (Apify Console → Settings → API & Integrations).
# Formato apify_api_xxx. Valor real en .env.local (gitignored) / Vercel; NUNCA commit.
APIFY_TOKEN=""
# Opcional: sobreescribe los actores por defecto (forma author/name).
# Defaults en código (aptos free tier): alvaraaz/infojobs-actor · valig/linkedin-jobs-scraper
# · valig/indeed-jobs-scraper (~$0.07/1k, sin mínimo; cubre 50+ países).
APIFY_INFOJOBS_ACTOR=""
APIFY_LINKEDIN_ACTOR=""
APIFY_INDEED_ACTOR=""

# ─── Google Books (vertical LIBROS) ───
# Opcional: la búsqueda funciona SIN clave (cuota baja). Con clave sube la cuota.
# https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=""

# Google Places API (New) para restaurantes y autocomplete de direcciones.
# Requiere billing activo. SOLO servidor; NUNCA exponer en cliente.
GOOGLE_PLACES_API_KEY=""

# ─── Tendencias RSS (Twitter/Reddit + noticias relacionadas) ───
# TwitterAPI.io: clave server-side para leer trends por WOEID. Si falta, el
# proveedor twitter se omite en el cron y se conserva la última caché de DB.
TWITTERAPI_IO_KEY=""
# Reddit API OAuth app-only: crear una app "script" o "web app" en
# https://www.reddit.com/prefs/apps. Solo se usa desde servidor/cron.
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
# Proveedores experimentales (off si están vacíos).
OUTX_API_KEY=""
XHS_PROVIDER_KEY=""
XUEQIU_PROVIDER_KEY=""
INSTAGRAM_PROVIDER_KEY=""
TIKTOK_PROVIDER_KEY=""
YOUTUBE_PROVIDER_KEY=""

# Firecrawl (firecrawl.dev) — RESPALDO de pago para menús de sitios con DataDome
# (Glovo/UberEats/JustEat). La fuente principal es Crawl4AI (gratis, ver abajo);
# Firecrawl solo entra si Crawl4AI no saca la carta. SOLO servidor.
FIRECRAWL_API_KEY=""

# ─── Crawl4AI (scraping de menús self-hosted, GRATIS) ───
# Servidor Crawl4AI (Docker) en el VPS, expuesto en scrape.nidokey.es tras nginx con
# TLS + bearer. Renderiza la web del restaurante → markdown; Claude (ANTHROPIC_API_KEY)
# lo estructura. Despliegue y artefactos en la carpeta crawl4ai/. SOLO servidor.
# Sin estas vars, el scraping cae al respaldo de Firecrawl. Genera el secreto con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRAWL4AI_URL=""
CRAWL4AI_SECRET=""

# ─── Viajes (Travelpayouts: Aviasales Data API + Hotellook) ───
# Alta INSTANTÁNEA en https://www.travelpayouts.com (sin llamada comercial).
# API token: Perfil → API token (disponible al registrarse, SIN verificar la web).
# SOLO servidor; valor real en .env.local (gitignored) / Vercel; NUNCA commit.
# Cubre vuelos (Aviasales) + hoteles (Hotellook); tren/bus van por afiliación aparte.
TRAVELPAYOUTS_TOKEN=""
# Marker = ID de afiliado (Perfil). NO se usa para datos; sí para construir los
# enlaces de afiliado de la capa de monetización (bloque 2).
TRAVELPAYOUTS_MARKER=""

# ─── Viajes · Hoteles (LiteAPI) ───
# Travelpayouts NO da datos de hotel → los precios de hotel vienen de LiteAPI.
# Alta self-serve instantánea en https://liteapi.travel → Perfil → Sandbox key.
# Monetización por MARGEN (parámetro `margin` = % que ganas por reserva).
# SOLO servidor (cabecera X-API-Key); valor real en .env.local / Vercel; NUNCA commit.
LITEAPI_KEY=""
# White-label de reserva de hoteles (LiteAPI/Nuitee). El botón "Reservar" abre
# esta web en in-app browser. Por defecto el sandbox del propietario.
LITEAPI_WHITELABEL_URL="https://alejandro-suances-isz5h.nuitee.link"

# ─── Viajes · Vuelos (Duffel) ───
# Precios de vuelo EN VIVO (cualquier ruta/fecha) — Travelpayouts solo tiene caché.
# Token en app.duffel.com → (organización) → Developers → Access tokens (modo test).
# Empieza por duffel_test_. SOLO servidor; valor real en .env.local / Vercel; NUNCA commit.
DUFFEL_TOKEN=""

# ─── Chat · Notificaciones push (opcional) ───
# Expo Push API funciona SIN token; este access token solo hace falta si activas
# "Enhanced Security for Push" en expo.dev. SOLO servidor (Vercel). El recibir
# push requiere un BUILD NATIVO (EAS), no basta OTA; iOS necesita APNs (Apple de pago).
EXPO_ACCESS_TOKEN=""

# ─── Chat · Adjuntos (Cloudflare R2) ───
# Bucket PRIVADO para fotos/archivos/notas de voz del chat. Sin estas 4 vars los
# adjuntos quedan APAGADOS automáticamente (deploy seguro). Crear en
# dash.cloudflare.com → R2: bucket (p. ej. "nidokey-chat", EU) y un API Token
# "Object Read & Write" limitado al bucket (Manage R2 API Tokens; el secret se
# muestra UNA vez). SOLO servidor; valores reales en .env.local / Vercel.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Opcional: URL S3 exacta que muestra Cloudflare junto a las claves. OBLIGATORIA
# si el bucket es de jurisdicción EU (https://<account_id>.eu.r2.cloudflarestorage.com);
# vacía = endpoint Default (https://<account_id>.r2.cloudflarestorage.com).
R2_ENDPOINT=""
# Kill switches (default activos cuando hay R2): CHAT_ENABLE_ATTACHMENTS=0 /
# CHAT_ENABLE_VOICE=0 para apagar adjuntos o notas de voz sin quitar R2.
# Retención: días tras los que el cron semanal /api/cron/chat-cleanup purga
# FÍSICAMENTE los mensajes con borrado suave (y sus adjuntos de R2). Vacío =
# conservar para siempre (el cron solo limpia huérfanos de R2 y tokens caducados).
CHAT_RETENTION_DAYS=""

# ─── Chat · Tiempo real (gateway WebSocket en el VPS, F3) ───
# Sin estas vars el chat funciona igual por POLLING (degradación elegante). El
# gateway vive en el VPS (carpeta gateway/) y NO recibe AUTH_SECRET ni DATABASE_URL.
# Los DOS secretos deben coincidir EXACTAMENTE con los de /etc/nidokey-gateway.env.
# URL pública del gateway tras Caddy (sin barra final).
CHAT_GATEWAY_URL=""
# Firma el webhook Vercel→gateway (HMAC). Genera: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHAT_GATEWAY_SECRET=""
# Firma los tickets WS que el móvil usa para conectar. Dedicado (NO es AUTH_SECRET).
CHAT_WS_SECRET=""
