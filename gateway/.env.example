# Gateway de tiempo real del chat — variables (NUNCA AUTH_SECRET ni DATABASE_URL).
# En el VPS, copia estos valores a /etc/nidokey-gateway.env (EnvironmentFile del
# servicio systemd). Genera secretos fuertes, p.ej.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Puerto local; Caddy hace de reverse proxy con TLS hacia él.
PORT=8787

# Valida los tickets WS del móvil. DEBE coincidir con CHAT_WS_SECRET en Vercel.
CHAT_WS_SECRET=

# Valida el HMAC del webhook desde Vercel. DEBE coincidir con CHAT_GATEWAY_SECRET en Vercel.
CHAT_GATEWAY_SECRET=

# Opcional: restringe el Origin de los WebSocket. El ticket es la auth real.
# ALLOWED_ORIGIN=
