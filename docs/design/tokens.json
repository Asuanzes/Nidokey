{
  "_comment": "Design tokens extraídos de src/app/globals.css y tailwind.config.ts. Fuente de verdad para web + mobile. Si cambias aquí, sincroniza ambos.",
  "color": {
    "surface": {
      "bg": "#FAFAF7",
      "default": "#FFFFFF",
      "muted": "#F4F3EE",
      "sunken": "#EFEEE8"
    },
    "border": {
      "default": "#E8E6E1",
      "strong": "#D4D1CA"
    },
    "text": {
      "default": "#1A1A18",
      "muted": "#6B6862",
      "subtle": "#9A9690",
      "inverse": "#FAFAF7"
    },
    "brand": {
      "primary": "#3A5F8A",
      "primaryHover": "#2E4D70",
      "primarySoft": "#EAEFF6",
      "primaryFg": "#FAFAF7",
      "accent": "#C49A4D",
      "_accentNote": "Latón envejecido sobre acero. Usar con moderación (CTAs destacados, brand mark)."
    },
    "semantic": {
      "success": { "fg": "#2D6A4F", "bg": "#E8F1EC" },
      "warning": { "fg": "#A86A17", "bg": "#F7EFDE" },
      "danger":  { "fg": "#A23E3E", "bg": "#F6E5E5" },
      "info":    { "fg": "#2C7A8A", "bg": "#E1EEF1" }
    },
    "priceDelta": {
      "up":   { "fg": "#A23E3E", "bg": "#FDF2F2" },
      "down": { "fg": "#2D6A4F", "bg": "#F0F7F2" }
    }
  },
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 8,
    "xl": 12,
    "_unit": "px"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(20, 20, 18, 0.04)",
    "sm": "0 1px 3px rgba(20, 20, 18, 0.06), 0 1px 2px rgba(20, 20, 18, 0.04)",
    "md": "0 4px 12px rgba(20, 20, 18, 0.06), 0 1px 3px rgba(20, 20, 18, 0.04)"
  },
  "typography": {
    "fontFamily": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "baseSize": 13,
    "lineHeight": 1.5,
    "fontFeatures": "cv11, ss01, ss03",
    "scale": {
      "xs": 11,
      "sm": 12,
      "base": 13,
      "md": 14,
      "lg": 16,
      "xl": 18,
      "2xl": 22,
      "3xl": 26,
      "_unit": "px"
    },
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "spacing": {
    "_unit": "px",
    "_comment": "Escala Tailwind por defecto (4px base): 0, 1, 2, 3, 4, 6, 8, 12, 16, 20, 24, 32, 40, 48"
  },
  "iconography": {
    "library": "lucide-react (web) / @expo/vector-icons Ionicons (mobile)",
    "brandIcons": ["IconKey (master)", "IconHorreo", "IconPicos"],
    "brandIconsPath": "src/components/brand/icons.tsx"
  },
  "platformNotes": {
    "web": "Tailwind utility classes mapean a estas vars en tailwind.config.ts. Tabular numerics via .tabular para precios.",
    "mobile": "StyleSheet.create con valores hex literales (no hay tokens runtime aún). Si en algún momento se unifica, exportar este JSON desde @nidokey/shared."
  }
}
