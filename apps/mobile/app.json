{
  "expo": {
    "name": "Nidokey",
    "slug": "nidokey",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/images/icon.png",
    "scheme": "nidokey",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bfbe4a8a-1899-44b5-b5a3-5e3742aabf4b"
    },
    "ios": {
      "bundleIdentifier": "es.nidokey.app",
      "supportsTablet": true,
      "appleTeamId": "6SPGZ83KG7",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.idealista.com"
            },
            {
              "scheme": "https",
              "host": "www.fotocasa.es"
            },
            {
              "scheme": "https",
              "host": "www.pisos.com"
            },
            {
              "scheme": "https",
              "host": "www.habitaclia.com"
            },
            {
              "scheme": "https",
              "host": "www.milanuncios.com"
            },
            {
              "scheme": "https",
              "host": "www.yaencontre.com"
            },
            {
              "scheme": "https",
              "host": "www.thinkspain.com"
            },
            {
              "scheme": "https",
              "host": "www.indomio.es"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#fcf7f0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.nidokey",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-blank.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF7",
          "dark": {
            "image": "./assets/images/splash-blank.png",
            "backgroundColor": "#141413"
          }
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          },
          "iosShareExtensionName": "Importar a Nidokey",
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nidokey usa la cámara para escanear el código de barras de tus libros.",
          "microphonePermission": "Nidokey usa el micrófono para grabar notas de voz en el chat.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Nidokey usa el micrófono para grabar notas de voz en el chat."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nidokey accede a tus fotos para enviarlas en el chat.",
          "cameraPermission": "Nidokey usa la cámara para hacer fotos y enviarlas en el chat."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nidokey usa tu ubicación para encontrar restaurantes cerca de ti."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "bfbe4a8a-1899-44b5-b5a3-5e3742aabf4b"
      }
    }
  }
}
