{
  "expo": {
    "name": "Nidokey",
    "slug": "nidokey",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nidokey",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "es.nidokey.app",
      "supportsTablet": true
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "www.idealista.com" },
            { "scheme": "https", "host": "www.fotocasa.es" },
            { "scheme": "https", "host": "www.pisos.com" },
            { "scheme": "https", "host": "www.habitaclia.com" },
            { "scheme": "https", "host": "www.milanuncios.com" },
            { "scheme": "https", "host": "www.yaencontre.com" },
            { "scheme": "https", "host": "www.thinkspain.com" },
            { "scheme": "https", "host": "www.indomio.es" }
          ],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#3a5f8a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.nidokey"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-blank.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF7",
          "dark": {
            "image": "./assets/images/splash-blank.png",
            "backgroundColor": "#141413"
          }
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          },
          "iosShareExtensionName": "Importar a Nidokey",
          "androidIntentFilters": ["text/*"]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nidokey usa la cámara para escanear el código de barras de tus libros.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
