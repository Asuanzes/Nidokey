generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PropertyType {
  HOUSE
  PISO
  ATICO
  CHALET
  DUPLEX
  ESTUDIO
  LOFT
  LOCAL
  TERRENO
  OTRO
}

enum PropertyStatus {
  FOR_SALE
  RESERVED
  SOLD
  WITHDRAWN
}

enum EnergyRating {
  A
  B
  C
  D
  E
  F
  G
  UNKNOWN
}

enum Portal {
  IDEALISTA
  FOTOCASA
  PISOS_COM
  MILANUNCIOS
  HABITACLIA
  YAENCONTRE
  THINKSPAIN
  INDOMIO
  OTHER
  MANUAL
}

enum ListingStatus {
  ACTIVE
  PRICE_DROP
  PRICE_UP
  SOLD
  REMOVED
  UNKNOWN
}

enum MediaKind {
  PHOTO
  FLOORPLAN
  VIDEO
  TOUR_3D
  DOCUMENT
}

enum MediaSource {
  USER_UPLOAD
  PORTAL_SCRAPE
  CADASTRE
  AI_SKETCH
  AI_RECONSTRUCTION
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts          Account[]
  sessions          Session[]
  apiTokens         ApiToken[]
  properties        Property[]
  cryptoHoldings    CryptoHolding[]
  marketInstruments MarketInstrument[]
  jobListings       JobListing[]
  bookRecords       BookRecord[]
  holidays          Holiday[]
}

// Tablas estándar de NextAuth / Auth.js (Prisma adapter).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  attempts   Int      @default(0) // intentos fallidos del OTP móvil; lock a los 5 (anti fuerza bruta)

  @@unique([identifier, token])
}

// Token API por usuario para los bookmarklets (cada usuario tiene el suyo).
// Lo embebimos en el .user.js generado dinámicamente.
model ApiToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  label     String?
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Property {
  id           String         @id @default(cuid())
  ownerId      String?
  owner        User?          @relation(fields: [ownerId], references: [id])

  // Discriminador de tipo de registro (records unificados). Aditivo: todas las
  // filas existentes son "property". Reservado para escalar a más tipos en el
  // futuro sin romper el modelo actual. Ver docs/arquitectura-records.md.
  recordType   String         @default("property")

  title        String
  description  String?
  type         PropertyType
  status       PropertyStatus @default(FOR_SALE)
  currentPrice Int?

  address      String?
  city         String
  province     String
  country      String         @default("España")
  postalCode   String?
  latitude     Float?
  longitude    Float?
  neighborhood String?

  environment  String?
  tags         String[]

  rooms        Int?
  bathrooms    Int?
  builtArea    Int?
  usableArea   Int?
  plotArea     Int?
  floor        String?
  hasElevator  Boolean?
  hasGarage    Boolean?
  hasStorage   Boolean?
  hasTerrace   Boolean?
  hasFireplace Boolean?
  hasGarden    Boolean?
  hasPool      Boolean?
  yearBuilt    Int?
  energyRating EnergyRating   @default(UNKNOWN)

  cadastralRef  String?
  cadastralData Json?

  // Cross-matching de portales
  titleSlug      String?  @db.VarChar(120)
  matchDismissed String[] @default([])

  notes        String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  media        Media[]
  listings     Listing[]
  priceHistory PriceSnapshot[]

  @@index([city, province])
  @@index([type, status])
  @@index([currentPrice])
  @@index([cadastralRef])
  @@index([titleSlug])
  @@index([city, builtArea])
  @@index([recordType])
}

model Media {
  id         String      @id @default(cuid())
  propertyId String
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  kind       MediaKind
  source     MediaSource @default(USER_UPLOAD)
  url        String
  caption    String?
  order      Int         @default(0)
  phash      String?     // dHash 64-bit en hex (16 chars)
  createdAt  DateTime    @default(now())

  @@index([propertyId, kind])
  @@index([phash])
}

model Listing {
  id            String          @id @default(cuid())
  propertyId    String
  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  portal        Portal
  url           String          @unique
  externalId    String?
  status        ListingStatus   @default(ACTIVE)
  lastPrice     Int?
  lastSeenAt    DateTime?
  lastCheckedAt DateTime?
  createdAt     DateTime        @default(now())

  snapshots     PriceSnapshot[]

  @@index([portal, status])
}

model PriceSnapshot {
  id         String         @id @default(cuid())
  listingId  String?
  listing    Listing?       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  price      Int
  status     ListingStatus?
  source     Portal
  observedAt DateTime       @default(now())

  @@index([propertyId, observedAt])
}

model MatchSuggestion {
  id          String   @id @default(cuid())
  sourceId    String
  targetId    String
  score       Int      // 0..100
  reasons     String[] @default([])
  blocked     Boolean  @default(false) // true si fue auto-merge bloqueado por safety
  blockedReason String?
  dismissedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceId, targetId])
  @@index([sourceId, dismissedAt])
  @@index([score, dismissedAt])
}

enum ImportLogKind {
  HASH
  CATASTRO
  GEOCODE
  MATCH
  MERGE_AUTO
  MERGE_MANUAL
  BORROW_FIELDS
  RECHECK
  TRAVELPAYOUTS
}

model ImportLog {
  id         String        @id @default(cuid())
  propertyId String?
  kind       ImportLogKind
  ok         Boolean       @default(true)
  message    String?
  meta       Json?
  createdAt  DateTime      @default(now())

  @@index([propertyId, createdAt])
  @@index([kind, createdAt])
  @@index([createdAt])
}

model SavedSearch {
  id        String   @id @default(cuid())
  ownerId   String?
  name      String
  portal    Portal
  url       String
  filters   Json
  active    Boolean  @default(true)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Registros multi-tipo (records unificados). Primer tipo nuevo: CRIPTO.
// Patrón común: tabla por tipo + tabla *Snapshot (generaliza PriceSnapshot).
// `currentValue`/`value` en céntimos de la moneda cotizada (Int) — consistente
// con Property.currentPrice. Nota: tokens sub-céntimo pierden precisión en Int;
// para esos casos se guarda el precio crudo en `meta` (futuro: Decimal).
// ─────────────────────────────────────────────────────────────────────────
model CryptoHolding {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  recordType    String   @default("crypto")

  title         String              // "Bitcoin"
  subtitle      String?             // "BTC · EUR"
  status        String?             // libre: "WATCH" | "HOLDING"
  symbol        String              // "BTC"
  quoteCurrency String   @default("EUR")
  quantity      Decimal? @db.Decimal(36, 18) // opcional: cantidad en cartera
  currentValue  Int?                // precio por unidad, céntimos de quoteCurrency
  currency      String?  @default("EUR")
  imageUrl      String?
  source        String?             // "coingecko" | "kraken" | …
  externalId    String?             // id de CoinGecko ("bitcoin")
  lastCheckedAt DateTime?
  meta          Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     CryptoSnapshot[]

  @@unique([ownerId, symbol, quoteCurrency, source])
  @@index([recordType])
  @@index([lastCheckedAt])
}

model CryptoSnapshot {
  id         String        @id @default(cuid())
  holdingId  String
  holding    CryptoHolding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  value      Int           // precio por unidad, céntimos
  source     String
  observedAt DateTime      @default(now())
  meta       Json?

  @@index([holdingId, observedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// MarketInstrument — instrumento de bolsa (acción/ETF/índice) seguido por el
// usuario. Mismo contrato común que CryptoHolding. Precio en céntimos.
// ─────────────────────────────────────────────────────────────────────────
model MarketInstrument {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  recordType    String   @default("market")

  title         String              // "Apple Inc."
  subtitle      String?             // "AAPL · NASDAQ"
  status        String?             // libre: "WATCH" | "HOLDING"
  symbol        String              // "AAPL"
  exchange      String?
  quoteCurrency String   @default("USD")
  quantity      Decimal? @db.Decimal(36, 18) // opcional: cantidad en cartera
  currentValue  Int?                // precio por unidad, céntimos de quoteCurrency
  currency      String?  @default("USD")
  imageUrl      String?
  source        String?             // "twelvedata" | "finnhub" | …
  externalId    String?             // símbolo normalizado
  lastCheckedAt DateTime?
  meta          Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     MarketSnapshot[]

  @@unique([ownerId, symbol, source])
  @@index([recordType])
  @@index([lastCheckedAt])
}

model MarketSnapshot {
  id           String           @id @default(cuid())
  instrumentId String
  instrument   MarketInstrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  value        Int              // precio por unidad, céntimos
  source       String
  observedAt   DateTime         @default(now())
  meta         Json?

  @@index([instrumentId, observedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// JobListing — oferta de empleo seguida por el usuario (vía Apify: InfoJobs,
// LinkedIn…). Mismo contrato común. `currentValue` = salario (mínimo) en
// céntimos cuando se conoce. Dedup por (ownerId, externalId, source).
// ─────────────────────────────────────────────────────────────────────────
model JobListing {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  recordType    String   @default("job")

  title         String              // "Frontend Developer (React)"
  subtitle      String?             // "Empresa · Ubicación"
  status        String?             // "OPEN" | "CLOSED"
  company       String?
  location      String?
  currentValue  Int?                // salario (mínimo) en céntimos
  currency      String?  @default("EUR")
  imageUrl      String?             // logo de la empresa
  url           String?             // URL de la oferta
  source        String?             // "apify"
  platform      String?             // "infojobs" | "linkedin"
  externalId    String?             // id/URL de la oferta en la plataforma
  lastCheckedAt DateTime?
  meta          Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     JobSnapshot[]

  @@unique([ownerId, externalId, source])
  @@index([recordType])
  @@index([lastCheckedAt])
}

model JobSnapshot {
  id         String     @id @default(cuid())
  listingId  String
  listing    JobListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  value      Int?       // salario si se sigue, céntimos
  status     String?
  source     String
  observedAt DateTime   @default(now())
  meta       Json?

  @@index([listingId, observedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// BookRecord — libro seguido (Google Books, fuente primaria; Open Library como
// fallback futuro). Mismo contrato común que las demás verticales, pero SIN
// *Snapshot: un libro no tiene serie temporal de valor. `currentValue` = rating
// medio * 100 (0–500) cuando se conoce. El modelo de dominio Book completo
// (packages/shared/src/book.ts) viaja en `meta.book`. Dedup por
// (ownerId, externalId=volumeId, source).
// ─────────────────────────────────────────────────────────────────────────
model BookRecord {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  recordType    String   @default("book")

  title         String              // título del libro
  subtitle      String?             // "Autor · 2017"
  status        String?             // libre: "WISHLIST" | "READING" | "READ"
  authors       String?             // autores unidos (denormalizado para orden/búsqueda)
  isbn13        String?
  currentValue  Int?                // rating medio * 100 (0–500), opcional
  currency      String?
  imageUrl      String?             // portada (thumbnail)
  source        String?             // "google_books"
  externalId    String?             // volumeId de Google Books
  lastCheckedAt DateTime?
  meta          Json?               // { book: Book, authors, isbn13 }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([ownerId, externalId, source])
  @@index([recordType])
}

// ─────────────────────────────────────────────────────────────────────────
// Holiday — VIAJE completo (vertical "Viajes"). Mismo contrato común que las
// demás verticales. Un registro = un viaje integrado: el alojamiento elegido y
// el desplazamiento elegido viven en `meta` (shape tipado en
// packages/shared/src/holiday.ts → HolidayTripMeta). `currentValue` = precio
// TOTAL del viaje en céntimos (transporte + alojamiento). Snapshot del total
// para histórico (los precios cambian hasta cerrar el viaje). Datos de búsqueda
// (vuelos/hoteles) vienen de Amadeus; tren/bus/coche y afiliados son capa aparte.
// Dedup por (ownerId, externalId, source).
// ─────────────────────────────────────────────────────────────────────────
model Holiday {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  recordType    String   @default("holiday")

  title         String              // "Viaje a Barcelona"
  subtitle      String?             // "15–20 jun 2026 · 5 días"
  status        String?             // libre: "PLANNING" | "BOOKED" | "DONE"
  destination   String?             // ciudad/destino ("Barcelona")
  startDate     DateTime?
  endDate       DateTime?
  currentValue  Int?                // precio TOTAL del viaje, céntimos de currency
  currency      String?  @default("EUR")
  imageUrl      String?             // foto del destino
  source        String?             // "amadeus" | "manual" | …
  externalId    String?             // clave estable del viaje (ruta+fechas, etc.)
  lastCheckedAt DateTime?
  meta          Json?               // HolidayTripMeta: transporte + alojamiento + comisión

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     HolidaySnapshot[]

  @@unique([ownerId, externalId, source])
  @@index([recordType])
  @@index([startDate])
}

model HolidaySnapshot {
  id         String   @id @default(cuid())
  holidayId  String
  holiday    Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  value      Int      // precio total del viaje en céntimos
  source     String
  observedAt DateTime @default(now())
  meta       Json?

  @@index([holidayId, observedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// RecordDuplicateDismissal — memoria de "no son duplicados" para la utilidad
// de duplicados de REGISTROS (libros/cripto/market/job/…). La detección es
// on-demand (no se almacenan sugerencias); aquí solo persisten los descartes
// del usuario para que un par NO vuelva a agruparse. `pairKey` = "<idA>|<idB>"
// con los ids ordenados (ver dismissPairKey en @nidokey/shared/dedup).
// ─────────────────────────────────────────────────────────────────────────
model RecordDuplicateDismissal {
  id         String   @id @default(cuid())
  ownerId    String
  recordType String
  pairKey    String
  createdAt  DateTime @default(now())

  @@unique([ownerId, pairKey])
  @@index([ownerId, recordType])
}
